            padding: 1rem;
            border: none;
            border-radius: 10px;
            background: rgba(255,255,255,0.9);
            font-family: inherit;
            font-size: 1rem;
        }

        .form-group textarea {
            height: 120px;
            resize: vertical;
        }

        .submit-btn {
            background: white;
            color: #d4a574;
            padding: 1rem 2.5rem;
            border: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1.1rem;
